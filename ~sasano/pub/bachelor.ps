dup 0 get
length 2 lt {
pop [ <00> 1 1 0 0 8.00 ]
} if
/ch-data exch def
currentfont /BitMaps get ch-code ch-data put
currentfont /Encoding get ch-code
dup s3 cvs cvn
put
} bind def
