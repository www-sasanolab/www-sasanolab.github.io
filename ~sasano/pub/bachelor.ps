/settray {
dup statusdict exch known {
{
statusdict begin load exec end
} stopped {
$error /newerror get {
$error /errorname get /rangecheck eq {
(Tray not found, using default tray.) print flush
/papertray false def
}{
handleerror
} ifelse
$error /newerror false put
} if
} if
}{
pop
} ifelse
} bind def
